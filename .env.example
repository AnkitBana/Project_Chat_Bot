# OpenAI Configuration
OPENAI_API_KEY=your_openai_api_key_here

# Anthropic (Claude) Configuration
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Google (Gemini) Configuration
GOOGLE_API_KEY=your_google_api_key_here

# Default provider: openai | anthropic | google
DEFAULT_LLM_PROVIDER=openai

# Models
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_MODEL=claude-3-5-haiku-20241022
GOOGLE_MODEL=gemini-2.0-flash

# Generation
# 0.3  → best for code (focused + correct)
# 0.7  → best for general chat / creative tasks
# 0.0  → fully deterministic (pure code bots)
TEMPERATURE=0.3

# 2048 → sharp, well-formatted responses
# 4096 → longer answers (essays, full modules)
# 8192 → maximum (use only when needed)
MAX_TOKENS=2048

# ICA (IBM Cognitive Architecture) — uses ak_... API key directly as Bearer token
ICA_API_KEY=ak_your_ica_api_key_here
ICA_BASE_URL=https://agentstudio.servicesessentials.ibm.com/v1
ICA_MODEL=gpt-5.2

# Production frontend URL (set this in Railway after Vercel deploy)
# FRONTEND_URL=https://your-app.vercel.app

# Logging
LOG_LEVEL=INFO
